<?xml version="1.0" encoding="utf-8"?>
<!--
  Each screen corner has two overlapping TextViews: a *_dark variant (light text, dark halo) for a
  dark/night map snippet, and a *_light variant (dark text, light halo) for a light/day snippet.
  RemoteViews can recolor text (setTextColor) but not the blur shadow that forms the halo
  (setShadowLayer isn't a @RemotableViewMethod), so the contrast flip is done by toggling which
  variant is visible — see NavLiveCardService.renderViews + the snippet-luminance detection in
  decodeCached (glass-nav-5um).
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="0dp">

    <ImageView
        android:id="@+id/snippet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="false"
        android:scaleType="centerCrop"
        android:contentDescription="@string/app_name" />

    <!-- Top-left: dark-map variant (light text / dark halo) over light-map variant. -->
    <TextView
        android:id="@+id/corner_top_left_dark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentLeft="true"
        android:padding="8dp"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:shadowColor="#FF000000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:text="" />

    <TextView
        android:id="@+id/corner_top_left_light"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentLeft="true"
        android:padding="8dp"
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold"
        android:shadowColor="#FFFFFFFF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:visibility="gone"
        android:text="" />

    <!-- Top-right. -->
    <TextView
        android:id="@+id/corner_top_right_dark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:padding="8dp"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="right"
        android:shadowColor="#FF000000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:text="" />

    <TextView
        android:id="@+id/corner_top_right_light"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:padding="8dp"
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="right"
        android:shadowColor="#FFFFFFFF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:visibility="gone"
        android:text="" />

    <!-- Bottom-left: amber accent, darkened for the light-map variant. -->
    <TextView
        android:id="@+id/corner_bottom_left_dark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentLeft="true"
        android:padding="8dp"
        android:textColor="#FFD580"
        android:textSize="28sp"
        android:textStyle="bold"
        android:shadowColor="#FF000000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:text="" />

    <TextView
        android:id="@+id/corner_bottom_left_light"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentLeft="true"
        android:padding="8dp"
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold"
        android:shadowColor="#FFFFFFFF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:visibility="gone"
        android:text="" />

    <!-- Bottom-right. -->
    <TextView
        android:id="@+id/corner_bottom_right_dark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentRight="true"
        android:padding="8dp"
        android:textColor="#FFD580"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="right"
        android:shadowColor="#FF000000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:text="" />

    <TextView
        android:id="@+id/corner_bottom_right_light"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentRight="true"
        android:padding="8dp"
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="right"
        android:shadowColor="#FFFFFFFF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:visibility="gone"
        android:text="" />

    <TextView
        android:id="@+id/status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:padding="8dp"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:shadowColor="#FF000000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:visibility="gone"
        android:text="" />

</RelativeLayout>
